# WhatsApp API Configuration
# Required for WhatsApp integration to work properly

# WhatsApp API Base URL (without /send-message endpoint)
WHATSAPP_API_URL=http://xx.xx.xx.xx

# WhatsApp API Credentials
WHATSAPP_API_USERNAME=admin
WHATSAPP_API_PASSWORD=your_secure_password

# WhatsApp API Timeout (in milliseconds)
WHATSAPP_API_TIMEOUT=10000

# WhatsPoints API Configuration (for sender registration)
# Backend-only (used in Vercel serverless functions)
WHATSPOINTS_API_URL=http://xx.xx.xx.xx:8080
WHATSPOINTS_API_USERNAME=admin
WHATSPOINTS_API_PASSWORD=your_secure_password

# Frontend Environment Variables (prefixed with VITE_)
# These are exposed to the browser, so don't put sensitive data here

# Enable/disable WhatsApp integration
VITE_WHATSAPP_ENABLED=true

# Development mode (logs messages instead of sending them)
VITE_WHATSAPP_DEVELOPMENT_MODE=false

# Notification settings
VITE_WHATSAPP_NOTIFY_ORDER_CREATED=true
VITE_WHATSAPP_NOTIFY_ORDER_COMPLETED=true

# Development settings (for local development only)
VITE_WHATSAPP_API_URL=http://localhost:8080
VITE_WHATSAPP_API_USERNAME=admin
VITE_WHATSAPP_API_PASSWORD=your_secure_password
VITE_WHATSAPP_API_TIMEOUT=10000

# WhatsPoints API (for development - uses client-side in dev mode)
VITE_WHATSPOINTS_API_URL=http://localhost:8080
VITE_WHATSPOINTS_API_USERNAME=admin
VITE_WHATSPOINTS_API_PASSWORD=your_dev_password
VITE_WHATSPOINTS_API_TIMEOUT=30000
VITE_WHATSPOINTS_REGISTRATION_URL=http://localhost:8080/register
